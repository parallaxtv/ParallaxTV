{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ParallaxTV",
  "version": "0.1.0",
  "identifier": "com.parallaxtv.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ParallaxTV",
        "width": 1280,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [ "lib/**/*" ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}